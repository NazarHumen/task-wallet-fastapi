# PostgreSQL settings (used by docker-compose to initialize the db service)
DB_NAME=taskwallet_db
DB_USER=user
DB_PASSWORD=password

# PostgreSQL connection URL (SQLAlchemy + psycopg2 driver)
# "db" is the docker-compose service name; from the host machine use localhost:5433 instead
DATABASE_URL=postgresql+psycopg2://user:password@db:5432/taskwallet_db

# Secret key for signing JWT access tokens.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=change-me-to-a-random-secret

# Algorithm used to sign JWTs
JWT_ALGORITHM="HS256"

# Access token lifetime, in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Refresh token lifetime, in days
REFRESH_TOKEN_EXPIRE_DAYS=7

# Stripe secret API key (Developers -> API keys in the Stripe Dashboard)
STRIPE_SECRET_KEY=sk_test_...

# Signing secret of the webhook endpoint.
# Locally: printed by the stripe-cli service on startup, see
#   docker compose logs stripe-cli
# In production: shown when registering the endpoint in the Stripe Dashboard
STRIPE_WEBHOOK_SECRET=whsec_...

# Where Stripe sends the user back after leaving Checkout
STRIPE_SUCCESS_URL=http://localhost:8000/payments/success
STRIPE_CANCEL_URL=http://localhost:8000/payments/cancel
